{
  "mappings": {
    "dynamic": "strict",
    "dynamic_templates": [
      {
        "external_ids_keywords": {
          "path_match": "external_ids.*",
          "mapping": {
            "type": "keyword",
            "ignore_above": 256
          }
        }
      }
    ],
    "properties": {
      "podcast_id": {
        "type": "keyword"
      },

      "external_ids": {
        "type": "object",
        "dynamic": true
      },

      "title": {
        "type": "text",
        "analyzer": "standard",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 256
          }
        }
      },

      "description": {
        "type": "text",
        "analyzer": "standard"
      },

      "publisher": {
        "type": "text",
        "analyzer": "standard",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 256
          }
        }
      },

      "language": {
        "type": "keyword"
      },

      "episode_count": {
        "type": "integer"
      },

      "popularity_score": {
        "type": "float"
      },

      "image_url": {
        "type": "keyword",
        "index": false
      },

      "created_at": {
        "type": "date"
      },

      "updated_at": {
        "type": "date"
      }
    }
  }
}