# Test environment — used in CI and local test runs.
# cp .env.test .env before running tests.

ES_HOST=http://localhost:9200

DATA_DIR=/tmp/podcast-search-test
SQLITE_PATH=/tmp/podcast-search-test/crawler.db
INGEST_CURSOR_PATH=/tmp/podcast-search-test/ingest_cursor.json

LOG_LEVEL=WARNING

INDEX_VERSION=1
REINDEX=false
ALLOW_DELETE_BASE_INDEX=false
ENABLE_LANGUAGE_SPLIT=true

INDEX_ZH_TW=test-episodes-zh-tw
INDEX_ZH_CN=test-episodes-zh-cn
INDEX_EN=test-episodes-en

SYNC_MODE=incremental

QUERY_LOG_PATH=/tmp/podcast-search-test/query_log.jsonl
CLICK_LOG_PATH=/tmp/podcast-search-test/click_log.jsonl
