# podcast-search environment variables
# Copy to .env and fill in values as needed.
# All variables have defaults; only override what differs from your setup.

# ---------------------------------------------------------------------------
# Data source
# ---------------------------------------------------------------------------
# Path to crawler.db and raw/rss/ (absolute or relative to repo root).
# Default: data/ inside this repo
DATA_DIR=../podcast-crawler/data

# ---------------------------------------------------------------------------
# Elasticsearch
# ---------------------------------------------------------------------------
ES_HOST=http://localhost:9200

# Remote ES authentication (leave blank for local dev)
# ES_API_KEY=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO   # DEBUG / INFO / WARNING / ERROR

# ---------------------------------------------------------------------------
# Index management
# ---------------------------------------------------------------------------
# ⚠️  INDEX_VERSION is a one-shot switch for reindex upgrades only.
#     Leave at 1 (default) during normal operation.
#     Set to 2 only when executing Phase 3-A reindex, then remove after
#     alias switch is complete. Leaving it at 2 will cause create_indices
#     to build _v2 backing indices and silently overwrite aliases.
INDEX_VERSION=1

REINDEX=false                  # Set true only during index upgrade
ALLOW_DELETE_BASE_INDEX=false  # Set true only if alias name conflicts with a concrete index

# ---------------------------------------------------------------------------
# Sync mode (embed_and_ingest)
# ---------------------------------------------------------------------------
SYNC_MODE=incremental   # full | incremental | backfill | single

# ---------------------------------------------------------------------------
# v2: Language split
# ---------------------------------------------------------------------------
ENABLE_LANGUAGE_SPLIT=true   # false = legacy single-index mode (v1 only)

# ---------------------------------------------------------------------------
# v2: ES index aliases (only override if you renamed them)
# ---------------------------------------------------------------------------
# INDEX_ZH_TW=episodes-zh-tw
# INDEX_ZH_CN=episodes-zh-cn
# INDEX_EN=episodes-en

# ---------------------------------------------------------------------------
# v2: SQLite data source
# ---------------------------------------------------------------------------
# SQLITE_PATH=data/crawler.db   # defaults to DATA_DIR/crawler.db

# ---------------------------------------------------------------------------
# v2: Behavioral log paths
# ---------------------------------------------------------------------------
# QUERY_LOG_PATH=logs/query_log.jsonl
# CLICK_LOG_PATH=logs/click_log.jsonl
# INGEST_CURSOR_PATH=data/ingest_cursor.json

# ---------------------------------------------------------------------------
# Embedding backend selection
# ---------------------------------------------------------------------------
# EMBEDDING_STRATEGY=local    # enum: local | api (default: local)
# EMBEDDING_API_URL=          # required when EMBEDDING_STRATEGY=api
# EMBEDDING_API_KEY=          # required when EMBEDDING_STRATEGY=api
# EMBEDDING_TIMEOUT_MS=2000   # ms; fallback to EmbeddingFallbackError on timeout
#
# Model names (optional — change only if switching models AND re-indexing)
# WARNING: changing these without re-running batch indexing causes vector space
#          mismatch and silently degrades kNN search quality.
# EMBEDDING_MODEL_ZH=BAAI/bge-base-zh-v1.5
# EMBEDDING_MODEL_EN=paraphrase-multilingual-MiniLM-L12-v2
