{
  "_source": {
    "includes": [
      "episode_id",
      "title",
      "description",
      "published_at",
      "duration_sec",
      "image_url",
      "language",
      "show.show_id",
      "show.title",
      "show.publisher",
      "show.image_url"
    ]
  },

  "query": {
    "bool": {
      "should": [
        {
          "multi_match": {
            "query": "{{query}}",
            "fields": ["title^3", "title.chinese^3", "description", "description.chinese"],
            "type": "best_fields"
          }
        }
      ],
      "minimum_should_match": 1
    }
  },

  "sort": [
    { "_score": { "order": "desc" } }
  ],

  "from": {{from}},
  "size": {{size}}
}
